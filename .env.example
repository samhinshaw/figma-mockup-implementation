# Copy to `.env` and fill in. Only VITE_-prefixed vars are exposed to the client.

# GraphQL endpoint for the graphql-request client (src/lib/graphql.ts).
# No live backend exists; with mocks enabled (below) this is intercepted by MSW
# and never actually hit. Point it at a real endpoint once one exists.
VITE_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# Set to "true" to run the in-browser MSW mock backend (src/mocks). Leave unset
# (or anything other than "true") to talk to the real VITE_GRAPHQL_ENDPOINT.
VITE_ENABLE_MOCKS=true
